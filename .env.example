S3_PROVIDER=oci
S3_REGION=eu-frankfurt-1
S3_NAMESPACE=replace-me
S3_IAM_USER_OCID=ocid1.user.oc1..replace-me
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_ADDRESSING_STYLE=path
S3_SOURCE_BUCKET=replace-me-source
S3_DESTINATION_BUCKET=replace-me-destination
ARCHIVER_RUN_TIMEOUT=7d
ARCHIVER_TEMP_DIR=/tmp/s3-archiver
LOG_LEVEL=INFO
LOG_DIR=/var/log/s3-archiver
ARCHIVER_CONFIG_JSON='[
  {
    "name": "oci-direct",
    "parser": "direct",
    "copy_mode": "direct",
    "source": {"path": "direct/"},
    "destination": {}
  },
  {
    "name": "oci-filename-daily",
    "parser": "filename_timestamp",
    "copy_mode": "daily_tar_gz",
    "source": {"path": "filename-daily/"},
    "destination": {}
  },
  {
    "name": "oci-folder-daily",
    "parser": "folder_timestamp",
    "copy_mode": "daily_tar_gz",
    "source": {"path": "folder-daily/"},
    "destination": {}
  },
  {
    "name": "oci-folder-child",
    "parser": "folder_timestamp_child",
    "copy_mode": "timestamp_child_tar_gz",
    "source": {"path": "folder-child/"},
    "destination": {}
  }
]'
