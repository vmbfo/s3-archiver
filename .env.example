S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_REGION=eu-frankfurt-1
ARCHIVER_RUN_TIMEOUT=7d
ARCHIVER_TEMP_DIR=/mnt/data/tmp/s3-archiver
ARCHIVER_MAX_SOURCE_OBJECT_SIZE_MIB=102400
ARCHIVER_MAX_DESTINATION_ARCHIVE_SIZE_MIB=102400
# Set CLEANUP=true to delete archived source objects automatically after each
# scheduled/automatic archive run. Defaults to false. The manual
# `s3-archiver cleanup` command ignores this and always cleans up.
CLEANUP=false
# Set ARCHIVER_BUCKET_WHITELIST_ENABLED=true to require every source and
# destination bucket in ARCHIVER_CONFIG_JSON to appear in
# ARCHIVER_BUCKET_WHITELIST (a JSON array of bucket names); startup fails
# otherwise. Defaults to false (no check). With the check enabled an empty
# list rejects every bucket, so nothing can run.
ARCHIVER_BUCKET_WHITELIST_ENABLED=false
ARCHIVER_BUCKET_WHITELIST=["my-source", "my-destination"]
LOG_LEVEL=INFO
LOG_DIR=/var/log/s3-archiver
ARCHIVER_CONFIG_JSON='[
  {
    "name": "direct",
    "parser": "direct",
    "copy_mode": "direct",
    "source": {"bucket": "my-source", "path": "direct/"},
    "destination": {"bucket": "my-destination"}
  }
]'
