S3_SOURCE_PROVIDER=oci
S3_SOURCE_ACCESS_KEY_ID=replace-me
S3_SOURCE_SECRET_ACCESS_KEY=replace-me
S3_SOURCE_REGION=eu-frankfurt-1
S3_SOURCE_NAMESPACE=replace-me
S3_SOURCE_BUCKET=replace-me-source
S3_SOURCE_IAM_USER_OCID=ocid1.user.oc1..replace-me
S3_SOURCE_ADDRESSING_STYLE=path
S3_DESTINATION_PROVIDER=oci
S3_DESTINATION_ACCESS_KEY_ID=replace-me
S3_DESTINATION_SECRET_ACCESS_KEY=replace-me
S3_DESTINATION_REGION=eu-frankfurt-1
S3_DESTINATION_NAMESPACE=replace-me
S3_DESTINATION_BUCKET=replace-me-destination
S3_DESTINATION_IAM_USER_OCID=ocid1.user.oc1..replace-me
S3_DESTINATION_ADDRESSING_STYLE=path
ARCHIVER_CONFIG_JSON=[{"name":"oci-daily","parser":"filename_timestamp","copy_mode":"daily_tar_gz","source":{"provider":"oci","region":"eu-frankfurt-1","namespace":"replace-me","bucket":"replace-me-source","path":"","access_key_id":"replace-me","secret_access_key":"replace-me","addressing_style":"path"},"destination":{"provider":"oci","region":"eu-frankfurt-1","namespace":"replace-me","bucket":"replace-me-destination","path":"","access_key_id":"replace-me","secret_access_key":"replace-me","addressing_style":"path"}}]
ARCHIVER_RUN_TIMEOUT=7d
ARCHIVER_TEMP_DIR=/tmp/s3-archiver
LOG_LEVEL=INFO
LOG_DIR=/var/log/s3-archiver
