S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_REGION=eu-frankfurt-1
ARCHIVER_RUN_TIMEOUT=7d
ARCHIVER_TEMP_DIR=/tmp/s3-archiver
LOG_LEVEL=INFO
LOG_DIR=/var/log/s3-archiver
ARCHIVER_CONFIG_JSON='[
  {
    "name": "direct",
    "parser": "direct",
    "copy_mode": "direct",
    "source": {"bucket": "my-source", "path": "direct/"},
    "destination": {"bucket": "my-destination"}
  }
]'
